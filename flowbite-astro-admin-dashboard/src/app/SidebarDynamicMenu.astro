---
import { url } from '../lib/data.js';
import SidebarDynamicMenu from './SidebarDynamicMenu.astro';

const { items, depth = 1 } = Astro.props;

const entries = Object.entries(items).sort(([aKey, aVal]: [string, any], [bKey, bVal]: [string, any]) => {
	// sort dirs first, then alphabetically
	if (aVal.isDir && !bVal.isDir) return -1;
	if (!aVal.isDir && bVal.isDir) return 1;
	return aKey.localeCompare(bKey);
});
---

{entries.map(([key, item]: [string, any]) => {
	if (item.isDir) {
		const dropdownId = `dropdown-pages-${key}-${Math.random().toString(36).substr(2, 6)}`;
		return (
			<li>
				<button
					type="button"
					class="flex items-center w-full p-2 text-base text-gray-900 transition duration-75 rounded-lg group hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700"
					style={`padding-left: ${2.75 + (depth - 1) * 1}rem;`}
					aria-controls={dropdownId}
					data-collapse-toggle={dropdownId}
				>
					<span class="flex-1 text-left whitespace-nowrap capitalize">{item.name}</span>
					<svg
						sidebar-toggle-item
						class="w-6 h-6"
						fill="currentColor"
						viewBox="0 0 20 20"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path
							fill-rule="evenodd"
							d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
							clip-rule="evenodd"
						/>
					</svg>
				</button>
				<ul id={dropdownId} class="hidden py-2 space-y-2">
					<SidebarDynamicMenu items={item.children} depth={depth + 1} />
				</ul>
			</li>
		);
	} else {
		return (
			<li>
				<a
					href={url(item.url)}
					class="flex items-center p-2 text-base text-gray-900 transition duration-75 rounded-lg group hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700"
					style={`padding-left: ${2.75 + (depth - 1) * 1}rem;`}
				>
					{item.name}
				</a>
			</li>
		);
	}
})}
